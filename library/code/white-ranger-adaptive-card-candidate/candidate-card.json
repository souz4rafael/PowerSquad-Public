{
 "type": "AdaptiveCard",
 "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
 "version": "1.5",
 "body": [
 {
 "type": "Container",
 "style": "emphasis",
 "bleed": true,
 "items": [
 {
 "type": "ColumnSet",
 "columns": [
 {
 "type": "Column",
 "width": "auto",
 "verticalContentAlignment": "Center",
 "items": [
 {
 "type": "Image",
 "style": "Person",
 "size": "Medium",
 "url": "https://adaptivecards.io/content/persona.png",
 "altText": "Candidate"
 }
 ]
 },
 {
 "type": "Column",
 "width": "stretch",
 "verticalContentAlignment": "Center",
 "items": [
 {
 "type": "TextBlock",
 "text": "${if(CandidateName, CandidateName, 'Candidate')}",
 "weight": "Bolder",
 "size": "Large",
 "wrap": true
 },
 {
 "type": "TextBlock",
 "text": "${if(Position, Position, 'Position not set')}",
 "isSubtle": true,
 "spacing": "None",
 "wrap": true
 }
 ]
 },
 {
 "type": "Column",
 "width": "auto",
 "verticalContentAlignment": "Center",
 "items": [
 {
 "type": "TextBlock",
 "text": "${if(Stage, Stage, 'Applied')}",
 "weight": "Bolder",
 "color": "Accent",
 "horizontalAlignment": "Right",
 "wrap": true
 }
 ]
 }
 ]
 }
 ]
 },
 {
 "type": "FactSet",
 "spacing": "Medium",
 "facts": [
 { "title": "Stage", "value": "${if(Stage, Stage, 'Applied')}" },
 { "title": "Annual comp", "value": "${if(AnnualComp, AnnualComp, 'N/A')}" },
 { "title": "Seniority", "value": "${if(SeniorityBand, SeniorityBand, 'N/A')}" },
 { "title": "Email", "value": "${if(Email, Email, 'N/A')}" }
 ]
 },
 {
 "type": "TextBlock",
 "text": "Summary",
 "weight": "Bolder",
 "spacing": "Medium",
 "wrap": true
 },
 {
 "type": "TextBlock",
 "text": "${if(Summary, Summary, 'No summary available for this candidate yet.')}",
 "wrap": true,
 "isSubtle": true
 }
 ],
 "actions": [
 {
 "type": "Action.OpenUrl",
 "title": "Open record",
 "url": "${if(RecordUrl, RecordUrl, 'https://make.powerapps.com')}"
 }
 ]
}
