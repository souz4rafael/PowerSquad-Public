# ==========================================================================
#  PowerSquad — environment configuration (template)
# ==========================================================================
#  Copy this file to `.env` at the repo root and fill in YOUR values, or run
#  the interactive helper:   pwsh ./setup/setup-powersquad.ps1
#
#  The real `.env` is git-ignored — your tenant details never get committed.
#  The squad's docs/scripts reference these as ${PLACEHOLDERS}; the setup gate
#  resolves them from this file at run time.
# ==========================================================================

# ---- Demo build target (the Power Platform environment you build in) ------
# The demo org you have admin on. Everything the squad builds goes here.
DEMO_ORG_URL=https://orgXXXXXXXX.crm.dynamics.com
# Host only (no scheme) — usually just DEMO_ORG_URL without https://
DEMO_ORG_HOST=orgXXXXXXXX.crm.dynamics.com
# The org's short id (the "orgXXXXXXXX" part of the URL)
DEMO_ORG_ID=orgXXXXXXXX

# Power Platform environment GUID + display name (Admin Center > Environments)
ENVIRONMENT_ID=00000000-0000-0000-0000-000000000000
ENVIRONMENT_NAME=YourDemoEnvironmentName

# Azure AD tenant GUID that owns the demo org
TENANT_ID=00000000-0000-0000-0000-000000000000

# The NATIVE admin of the demo tenant (build identity — see identity.md)
ADMIN_UPN=admin@yourdemotenant.onmicrosoft.com
# Short display name of that admin account (optional, cosmetic)
ADMIN_USER=Admin

# ---- Your Scout / corporate identity (for context tools, optional) --------
# Your work email (used for notifications / test sends in demos)
USER_EMAIL=you@example.com
# Your OS username (used to resolve local paths). e.g. the folder in C:\Users\<USER>
USER=yourusername
# Your home dir where Scout stores config (usually C:\Users\<USER>)
SCOUT_HOME=C:\Users\yourusername

# Corporate (home) tenant — only needed if you sign into a CRM/opportunity
# source or an enablement library as a guest in the demo tenant. Leave blank
# if not applicable.
CORP_TENANT_ID=
CORP_DOMAIN=yourcompany.com
CORP_EMAIL=you@yourcompany.com

# ---- Optional context sources (read-only) ---------------------------------
# CRM Sales host, if your org uses one for opportunity/account context.
CRM_SALES_HOST=
# Enablement / content library host (e.g. a sales content platform), if any.
CONTENT_LIBRARY_HOST=

# ---- Tooling --------------------------------------------------------------
# The MCP server name registered in Scout that targets your Dataverse env.
DEMO_MCP=YOUR-DATAVERSE-MCP
